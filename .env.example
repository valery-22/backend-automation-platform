# FastAPI Configuration
FAST_API_HOST=0.0.0.0
FAST_API_PORT=8000
FAST_API_RELOAD=true
FAST_API_WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://automation_user:automation_password@postgres:5432/automation_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# GitHub API Configuration
GITHUB_API_TOKEN=your_github_token_here
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=code_embeddings
QDRANT_VECTOR_SIZE=1536

# Event Stream Configuration
EVENT_STREAM_ENABLED=true
EVENT_STREAM_BATCH_SIZE=100
EVENT_STREAM_TIMEOUT_SECONDS=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application Configuration
APP_NAME=Backend Automation Platform
APP_VERSION=1.0.0
APP_ENV=development
